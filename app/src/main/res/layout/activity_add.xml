<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    android:id="@+id/main"
    android:background="#F5F7FA">

    <!-- Tiêu đề -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thêm phòng trọ"
        android:textColor="#1E293B"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- Tên phòng -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutTenPhong"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Tên phòng"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtTenPhong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Giá phòng -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutGiaPhong"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Giá phòng (VNĐ)"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/layoutTenPhong"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtGiaPhong"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:layout_marginHorizontal="10dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Số điện -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutSoDien"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Số điện hiện tại"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/layoutGiaPhong"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtSoDien"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:layout_marginHorizontal="10dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Số nước -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutSoNuoc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Số nước hiện tại"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/layoutSoDien"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtSoNuoc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:layout_marginHorizontal="10dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Trạng thái -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/layoutTrangThai"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="Trạng thái (Trống / Đã thuê)"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        app:layout_constraintTop_toBottomOf="@id/layoutSoNuoc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtTrangThai"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Nút tiếp -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTiep"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="THÊM KHÁCH VÀO PHÒNG"
        android:textColor="@android:color/white"
        app:backgroundTint="#22C55E"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTrangThai"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- Thêm phòng -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThemphong"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="THÊM PHÒNG"
        android:textColor="@android:color/white"
        app:backgroundTint="#00CCFF"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnTiep"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Xóa -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnXoa"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="XÓA"
        android:textColor="@android:color/white"
        app:backgroundTint="#EF4444"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnThemphong"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

    <!-- Thoát -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnThoat"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="THOÁT"
        android:textColor="#000000"
        app:backgroundTint="#FACC15"
        app:cornerRadius="12dp"
        app:layout_constraintTop_toBottomOf="@id/btnXoa"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
